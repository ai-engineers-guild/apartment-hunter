# === LLM Providers ===
# At least one is required for apartment analysis
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === Telegram Notifications (optional) ===
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# === Paths (defaults are fine for local dev) ===
# DB_PATH=data/apartments.db
# CHROMA_PATH=data/chroma

# === Scraping ===
# SCRAPE_INTERVAL_MINUTES=30
# SCRAPE_DELAY_SECONDS=2.0

# === Embedding Model ===
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# === Server ===
# MCP_TRANSPORT=stdio
# API_HOST=0.0.0.0
# API_PORT=8000

# === LLM Settings ===
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o
